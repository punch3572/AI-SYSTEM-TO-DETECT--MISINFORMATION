{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start local server",
            "type": "shell",
            "command": "node server.js",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "TrustLens running at http://localhost:8080"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
